# wrangler 4.107.0 declares an OPTIONAL peer on @cloudflare/workers-types@^4,
# but this repo pins the newer ^5 types (they are a superset and typecheck
# clean). Modern npm still treats that optional-peer mismatch as a hard
# ERESOLVE under `npm ci`, which broke CI on a fresh clone. Since the peer is
# optional and the tree is otherwise valid, tell npm to accept it.
legacy-peer-deps=true
